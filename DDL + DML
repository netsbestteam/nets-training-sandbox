CREATE EXTENSION IF NOT EXISTS "uuid-ossp";
CREATE EXTENSION IF NOT EXISTS "postgis";
SELECT uuid_generate_v4();

DROP TABLE IF EXISTS camera.cameras;
CREATE TABLE IF NOT EXISTS camera.cameras (
	camera_id UUID PRIMARY KEY DEFAULT uuid_generate_v4(),
	name TEXT UNIQUE NOT NULL,
	status TEXT CHECK(status IN ('active', 'inactive', 'fault')) NOT NULL,
	creation_date DATE DEFAULT now() NOT NULL,
	location geography(Point, 4326),
	direction FLOAT CHECK(direction >= 0 AND direction <= 360)
);

DROP TABLE IF EXISTS camera.investigators;
CREATE TABLE IF NOT EXISTS camera.investigators (
	investigator_id UUID PRIMARY KEY DEFAULT uuid_generate_v4(),
	full_name TEXT NOT NULL,
	team TEXT,
	is_active BOOLEAN NOT NULL
);

DROP TABLE IF EXISTS camera.alerts;
CREATE TABLE IF NOT EXISTS camera.alerts (
    alert_id UUID PRIMARY KEY DEFAULT uuid_generate_v4(),
    severity INT CHECK (severity >= 1 AND severity <= 5) NOT NULL,
    alert_type TEXT,
    alert_time TIMESTAMP DEFAULT now() NOT NULL,
    status TEXT,
    location geography(Point, 4326),
    camera_id UUID REFERENCES cameras(camera_id) ON DELETE CASCADE
);

CREATE TABLE IF NOT EXISTS camera.alert_assignments (
	assignment_id SERIAL PRIMARY KEY,
	investigator_id UUID REFERENCES investigators(investigator_id) ON DELETE RESTRICT,
	alert_id UUID REFERENCES alerts(alert_id) ON DELETE CASCADE,
	assignment_start TIMESTAMPTZ DEFAULT now() NOT NULL,
	assignment_end TIMESTAMPTZ
);



